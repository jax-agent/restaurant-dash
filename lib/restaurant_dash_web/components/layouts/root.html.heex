<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Order Base">
      {assigns[:page_title]}
    </.live_title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <%!-- Inter font from Google Fonts --%>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <%!-- Leaflet via CDN (avoids esbuild PNG bundling issues) --%>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin="">
    </script>
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
  </head>
  <body>
    <%!-- Demo mode banner — sleek, blurred, dismissible --%>
    <%= if Map.get(assigns, :demo_mode, false) do %>
      <div
        class="demo-banner"
        id="demo-banner"
        role="alert"
      >
        <div class="max-w-7xl mx-auto px-4 h-10 flex items-center justify-between gap-3">
          <div class="flex items-center gap-2 text-white">
            <span class="text-sm">🎯</span>
            <span class="text-xs sm:text-sm font-medium text-white/90">
              <span class="hidden sm:inline">
                Exploring <strong class="text-white">Order Base</strong>
                in demo mode — changes reset periodically
              </span>
              <span class="sm:hidden font-semibold text-white">Demo mode</span>
            </span>
            <a
              href="/signup"
              class="ml-2 bg-white/20 hover:bg-white/30 text-white text-xs font-bold px-3 py-1 rounded-full border border-white/30 transition-all whitespace-nowrap"
            >
              Sign up free →
            </a>
          </div>
          <button
            onclick="document.getElementById('demo-banner').style.display='none'"
            class="text-white/60 hover:text-white transition-colors ml-2 flex-shrink-0 text-lg leading-none"
            aria-label="Dismiss"
          >
            ×
          </button>
        </div>
      </div>
    <% end %>
    <%!-- User bar: desktop only, dark minimal style --%>
    <%= if @current_scope do %>
      <div class="user-bar hidden md:flex" style="background: #111; border-color: #222;">
        <span class="text-gray-500 hidden lg:block">{@current_scope.user.email}</span>
        <.link href={~p"/users/settings"} class="hover:text-white" style="color: #888;">
          Settings
        </.link>
        <.link
          href={~p"/users/log-out"}
          method="delete"
          class="hover:text-red-400"
          style="color: #666;"
        >
          Log out
        </.link>
      </div>
    <% else %>
      <div class="user-bar hidden md:flex" style="background: #111; border-color: #222;">
        <.link href={~p"/users/register"} style="color: #888;">Register</.link>
        <.link href={~p"/users/log-in"} style="color: #888;">Log in</.link>
      </div>
    <% end %>
    {@inner_content}
  </body>
</html>
