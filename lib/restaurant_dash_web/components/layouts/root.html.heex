<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Order Base">
      {assigns[:page_title]}
    </.live_title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <%!-- Leaflet via CDN (avoids esbuild PNG bundling issues) --%>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin="">
    </script>
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
  </head>
  <body>
    <%!-- Demo mode banner --%>
    <%= if Map.get(assigns, :demo_mode, false) do %>
      <div class="w-full bg-amber-500 text-white text-center py-2 px-4 text-sm font-medium flex items-center justify-center gap-2 flex-wrap">
        <span class="text-xs sm:text-sm">
          🎯
          <span class="hidden sm:inline">
            You're exploring <strong>Order Base</strong>
            in demo mode — all changes are reset periodically
          </span>
          <span class="sm:hidden"><strong>Demo mode</strong> — resets periodically</span>
        </span>
        <a
          href="/signup"
          class="bg-white text-amber-600 hover:bg-amber-50 font-bold px-2 py-0.5 sm:px-3 sm:py-1 rounded-lg text-xs transition-colors whitespace-nowrap"
        >
          Sign up →
        </a>
      </div>
    <% end %>
    <%!-- User bar: hidden on mobile (owner dashboard has its own mobile nav), visible on desktop --%>
    <ul class="menu menu-horizontal w-full relative z-10 items-center gap-4 px-4 sm:px-6 lg:px-8 justify-end hidden md:flex">
      <%= if @current_scope do %>
        <li class="text-sm text-gray-500 hidden lg:block">
          {@current_scope.user.email}
        </li>
        <li>
          <.link href={~p"/users/settings"}>Settings</.link>
        </li>
        <li>
          <.link href={~p"/users/log-out"} method="delete">Log out</.link>
        </li>
      <% else %>
        <li>
          <.link href={~p"/users/register"}>Register</.link>
        </li>
        <li>
          <.link href={~p"/users/log-in"}>Log in</.link>
        </li>
      <% end %>
    </ul>
    {@inner_content}
  </body>
</html>
