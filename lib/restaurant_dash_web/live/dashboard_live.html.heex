<%!-- White-label CSS variable injection --%>
<style>
  :root {
    --primary: <%= @branding.primary_color %>;
  }
</style>

<%!-- Header --%>
<header class="dashboard-header" style="background-color: var(--primary);">
  <div class="header-inner">
    <div class="header-brand">
      <span class="header-logo">{@branding.logo_url}</span>
      <span class="header-name" id="restaurant-name">{@branding.restaurant_name}</span>
    </div>
    <a href="/orders/new" class="btn-new-order" style="text-decoration:none;">+ New Order</a>
  </div>
</header>

<%!-- Sidebar + Main --%>
<div class="dashboard-layout">
  <%!-- Sidebar --%>
  <aside class="sidebar">
    <h2 class="sidebar-title">Status</h2>
    <%= for status <- @statuses do %>
      <div class="sidebar-item">
        <span class={["status-dot", "dot-#{status}"]}></span>
        <span class="sidebar-label">{humanize_status(status)}</span>
        <span class="sidebar-count">{Map.get(@status_counts, status, 0)}</span>
      </div>
    <% end %>
  </aside>

  <%!-- Kanban + Map --%>
  <main class="main-content">
    <%!-- Kanban board --%>
    <section class="kanban-board" id="kanban-board">
      <%= for status <- @statuses do %>
        <div class="kanban-col" id={"col-#{status}"}>
          <div class="kanban-col-header">
            <span class={["status-badge", "badge-#{status}"]}>{humanize_status(status)}</span>
            <span class="col-count">{length(Map.get(@orders, status, []))}</span>
          </div>
          <div class="kanban-cards">
            <%= for order <- Map.get(@orders, status, []) do %>
              <div class="order-card" id={"order-#{order.id}"}>
                <div class="card-top">
                  <span class="card-customer">{order.customer_name}</span>
                  <span class={["status-badge", "badge-#{order.status}"]}>
                    {humanize_status(order.status)}
                  </span>
                </div>
                <div class="card-meta">
                  <span class="card-items">
                    {length(order.items)} item{if length(order.items) != 1, do: "s"}
                  </span>
                  <span class="card-time">{time_ago(order.inserted_at)}</span>
                </div>
                <div class="card-address">{order.delivery_address}</div>
                <%= if order.phone do %>
                  <div class="card-phone">{order.phone}</div>
                <% end %>
                <div class="card-actions">
                  <a href={"/orders/#{order.id}/edit"} class="card-action-btn card-edit-btn">
                    ✏️ Edit
                  </a>
                  <%= if order.payment_intent_id && order.payment_status not in ["refunded", "failed"] do %>
                    <button
                      phx-click="refund_order"
                      phx-value-id={order.id}
                      data-confirm={"Refund order for #{order.customer_name}? This cannot be undone."}
                      class="card-action-btn"
                      style="color: #d97706; border-color: #d97706;"
                    >
                      💸 Refund
                    </button>
                  <% end %>
                  <%= if order.payment_status == "refunded" do %>
                    <span class="card-action-btn" style="color: #6b7280; cursor: default;">
                      ✓ Refunded
                    </span>
                  <% end %>
                  <button
                    phx-click="delete_order"
                    phx-value-id={order.id}
                    data-confirm={"Delete order for #{order.customer_name}?"}
                    class="card-action-btn card-delete-btn"
                  >
                    🗑️ Delete
                  </button>
                </div>
              </div>
            <% end %>
            <%= if Enum.empty?(Map.get(@orders, status, [])) do %>
              <div class="empty-col">No orders</div>
            <% end %>
          </div>
        </div>
      <% end %>
    </section>

    <%!-- Delivery Map --%>
    <section class="map-section">
      <h2 class="map-title">Live Delivery Map</h2>
      <div
        id="delivery-map"
        phx-hook="DeliveryMap"
        phx-update="ignore"
        data-orders={Jason.encode!(@active_deliveries |> Enum.map(&order_map_data/1))}
        data-primary-color={@branding.primary_color}
        class="map-container"
      >
      </div>
    </section>
  </main>
</div>

<%!-- Flash Messages --%>
<.flash kind={:info} flash={@flash} />
<.flash kind={:error} flash={@flash} />
